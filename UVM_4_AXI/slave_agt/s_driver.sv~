class slave_driver extends uvm_driver #(signal_xtn);

`uvm_component_utils(slave_driver)

virtual axi_if.SDR_MP vif;

slave_agt_config m_cfg;

static bit [31:0]sq_awaddr[$];
static bit [7:0]s_awlen[$];
static bit [2:0]s_awsize[$];

static bit [3:0] s_arid_q[$];
static bit [31:0]s_araddr_q[$];
static bit [7:0] s_arlen_q[$];
static bit [2:0] s_arsize_q[$];
static bit [1:0] s_arburst_q[$]; 

 bit [3:0]bid_q[$];
 bit [7:0]len;
 
rand bit [31:0]rdata[];
semaphore sem0= new(1);
semaphore sem1= new(1);
semaphore sem2= new(1);
semaphore sem3= new(1);
semaphore sem4= new(1);

static int j=0;



extern function new(string name="slave_driver",uvm_component parent);
extern function void build_phase(uvm_phase phase);
extern function void connect_phase(uvm_phase phase);
extern task run_phase(uvm_phase phase);
extern task send_to_master(signal_xtn xtn,int j);
extern task wr_addr_ch(signal_xtn xtn,int j);
extern task wr_data_ch(signal_xtn xtn,int j);
extern task wr_resp_ch();
extern task rd_addr_ch();
extern task rd_data_ch(signal_xtn xtn);
extern task store_data(signal_xtn xtn);
extern task addr_calc(signal_xtn xtn);
endclass

function slave_driver::new(string name="slave_driver",uvm_component parent);
  super.new(name,parent);
endfunction

function void slave_driver::build_phase(uvm_phase phase);
  super.build_phase(phase);
 if(!uvm_config_db #(slave_agt_config)::get(this,"","slave_agt_config",m_cfg))
   `uvm_fatal("SLAVE_DRIVER","cannot get() it have u set() it?")

endfunction

function void slave_driver::connect_phase(uvm_phase phase);
 vif=m_cfg.vif;
endfunction

task slave_driver::run_phase(uvm_phase phase);
  forever begin
	seq_item_port.get_next_item(req);
        send_to_master(req,j);
    seq_item_port.item_done();
	j++;
  end

endtask

task slave_driver::send_to_master(signal_xtn xtn,int j);

 fork
  wr_addr_ch(xtn,j);
  wr_data_ch(xtn,j);
  wr_resp_ch();
  rd_addr_ch();
  rd_data_ch(xtn);
 join_none
 


endtask

task slave_driver::wr_addr_ch(signal_xtn xtn,int j);
sem0.get(1);
$display($time,">>>>>>>>>>>>>>>>>SLAVE DRIVER COME WR_ADDRESS_CHANNEL =%0d<<<<<<<<<<<<<<<<<<<<<<<<<<<",j);
//wait(vif.sdr_cb.awvalid);
 @(vif.sdr_cb);
   vif.sdr_cb.awready <= 1;
   wait(vif.sdr_cb.awvalid);
@(vif.sdr_cb);

   while(vif.sdr_cb.awvalid)
   begin
		bid_q.push_back(vif.sdr_cb.awid);
$display($time,"111111111111111111111111111111111  bid_q=%p",bid_q);
		sq_awaddr.push_back(vif.sdr_cb.awaddr);
		s_awlen.push_back(vif.sdr_cb.awlen);
		s_awsize.push_back(vif.sdr_cb.awsize);
		xtn.s_awburst=vif.sdr_cb.awburst;
		@(vif.sdr_cb); 	
   end
sem0.put(1);

$display($time,"<<<<<<<<<<<<<<<<<<<SLAVE DRIVER COME OUT WR_ADDRESS_CHANNEL =%0d >>>>>>>>>>>>>>>>>>>>>",j);
endtask

task slave_driver::wr_data_ch(signal_xtn xtn,int j);
sem1.get(1);
$display($time,">>>>>>>>>>>>>>>SLAVE DRIVER COME WR_DATA_CHANNEL =%0d<<<<<<<<<<<<<<<<<<<<<<<<<<<",j);
@(vif.sdr_cb);
vif.sdr_cb.wready <= 1;
wait(vif.sdr_cb.wvalid);
 @(vif.sdr_cb);
 if(sq_awaddr.size!=0)
  begin
	xtn.s_awaddr=sq_awaddr.pop_front();
  end
 		
 while(vif.sdr_cb.wvalid==1)
 begin
  store_data(xtn);
  @(vif.sdr_cb);
  if(xtn.s_wlast==1)
  begin
	if(sq_awaddr.size!=0)
  	begin
		xtn.s_awaddr=sq_awaddr.pop_front();
  	end
  end
 end
if(vif.sdr_cb.wvalid==0)
	sem1.put(1);
$display($time,"<<<<<<<<<<<<<<<SLAVE DRIVER COME OUT WR_DATA_CHANNEL =%0d>>>>>>>>>>>>>>>>>>>>",j);   
endtask

task slave_driver::store_data(signal_xtn xtn);

  xtn.s_wdata = vif.sdr_cb.wdata;
  xtn.s_wstrb = vif.sdr_cb.wstrb;
  xtn.s_wlast = vif.sdr_cb.wlast;

  
  case(xtn.s_wstrb)
	4'b0001:xtn.mask_data  = xtn.s_wdata & 32'h000000ff;
	4'b0010:xtn.mask_data  = xtn.s_wdata & 32'h0000ff00;
	4'b0100:xtn.mask_data  = xtn.s_wdata & 32'h00ff0000;
	4'b1000:xtn.mask_data  = xtn.s_wdata & 32'hff000000;
	4'b0011:xtn.mask_data  = xtn.s_wdata & 32'h0000ffff;
	4'b1100:xtn.mask_data  = xtn.s_wdata & 32'hffff0000;
	4'b1110:xtn.mask_data  = xtn.s_wdata & 32'hffffff00;
	4'b1111:xtn.mask_data  = xtn.s_wdata & 32'hffffffff;
  endcase
  
  xtn.s_data[xtn.s_awaddr] = xtn.mask_data;
  $display($time,"s_data[%0d]=%h",xtn.s_awaddr,xtn.s_data[xtn.s_awaddr]);
  addr_calc(xtn);
endtask
 
task slave_driver::addr_calc(signal_xtn xtn);
 if(xtn.s_awburst!=2'b00)
 begin
	xtn.s_awaddr = xtn.s_awaddr + xtn.no_of_byte;
	if(xtn.s_awaddr % xtn.no_of_byte==0)
	begin
		if(xtn.s_awburst==2'b10)
		begin
			$display("Aligned address");
			if(xtn.s_awaddr >= xtn.wrap_boundry)
			xtn.s_awaddr = xtn.aligned_addr;
			$display("Wrap mode & aligned addressS");
		end
	end
	
	else
	begin
		xtn.s_awaddr = xtn.s_awaddr - (xtn.s_awaddr % xtn.no_of_byte);
		if(xtn.s_awburst==2'b10)
		begin
			$display("Unaligned address");
			if(xtn.s_awaddr >= xtn.wrap_boundry)
			xtn.s_awaddr = xtn.aligned_addr;
			$display("wrap mode & Unaligned address");
		end
	end
 end
 else
  xtn.s_awaddr = xtn.s_awaddr;
 endtask




task slave_driver::wr_resp_ch();
$display($time,">>>>>>>>>>>>>>>>>SLAVE DRIVER COME WR_RESPONSE_CHANNEL =%0d<<<<<<<<<<<<<<<<<<<<<<<<<<<",j);
sem2.get(1);
 if(!vif.sdr_cb.aresetn)
        begin
	  @(vif.sdr_cb);
          vif.sdr_cb.bvalid <= 0;
        end
  wait(vif.sdr_cb.bready);


   
  if(bid_q.size!=0)
    vif.sdr_cb.bid    <= bid_q.pop_front();
    vif.sdr_cb.bvalid <= 1;
    vif.sdr_cb.bresp  <= 0;
	@(vif.sdr_cb);
        @(vif.sdr_cb);
   vif.sdr_cb.bid    <= 0;
   vif.sdr_cb.bvalid <= 0;
   @(vif.sdr_cb);
wait(vif.sdr_cb.wlast);
sem2.put(1);   
    

$display($time,"<<<<<<<<<<<<<<<SLAVE DRIVER COME OUT WR_RESPONSE_CHANNEL =%0d>>>>>>>>>>>>>>>>>>>>>>>>>>",j);
endtask


task slave_driver::rd_addr_ch();
$display($time,">>>>>>>>>>>>>>>>>SLAVE DRIVER COME READ_ADDRESSS_CHANNEL <<<<<<<<<<<<<<<<<<<<<<<<<<<");
sem3.get(1);

@(vif.sdr_cb);
 vif.sdr_cb.arready <= 1;
wait(vif.sdr_cb.arvalid);
@(vif.sdr_cb);
 while(vif.sdr_cb.arvalid)
   begin
	
	s_arid_q.push_back(vif.sdr_cb.arid);
	s_araddr_q.push_back(vif.sdr_cb.araddr);
	s_arlen_q.push_back(vif.sdr_cb.arlen);
	s_arsize_q.push_back(vif.sdr_cb.arsize);
	s_arburst_q.push_back(vif.sdr_cb.arburst);
	@(vif.sdr_cb); 	
   end
 
sem3.put(1);
$display($time,">>>>>>>>>>>>>>>>>SLAVE DRIVER COME OUT READ_ADDRESSS_CHANNEL <<<<<<<<<<<<<<<<<<<<<<<<<<<");
endtask

task slave_driver::rd_data_ch(signal_xtn xtn);
$display($time,">>>>>>>>>>>>>>>>>SLAVE DRIVER COME READ_DATA_CHANNEL <<<<<<<<<<<<<<<<<<<<<<<<<<<");
sem4.get(1);
      if(!vif.sdr_cb.aresetn)
        begin
	  @(vif.sdr_cb);
          vif.sdr_cb.rvalid <= 0;
        end
 wait(vif.sdr_cb.rready);
 @(vif.sdr_cb);
 @(vif.sdr_cb);
 if(s_arid_q.size!=0)
	vif.sdr_cb.rid <= s_arid_q.pop_front();
 if(s_arlen_q.size!=0)
	len=s_arlen_q.pop_front();
 $display($time,"length=%0d",len);
 rdata=new[len+1];
 foreach(rdata[i])
   rdata[i]=$random;
 for(int i=0;i<(len+1);i++)
  begin
	
	vif.sdr_cb.rdata	<= rdata[i];
	vif.sdr_cb.rvalid	<= 1;
	
	if(i==len)
	       vif.sdr_cb.rlast <= 1;
	else
	       vif.sdr_cb.rlast<= 0;
		
	@(vif.sdr_cb);
$display($time,"rdata[%0d]=%h",i,rdata[i]);
  end
  
  vif.sdr_cb.rresp <= 0;
  vif.sdr_cb.rlast <= 0;
  vif.sdr_cb.rdata <= 0;
  
  
sem4.put(1);
$display($time,">>>>>>>>>>>>>>>>>SLAVE DRIVER COME OUT READ_DATA_CHANNEL <<<<<<<<<<<<<<<<<<<<<<<<<<<");
endtask

