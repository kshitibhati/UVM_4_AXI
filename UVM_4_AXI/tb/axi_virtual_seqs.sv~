class axi_vbase_seq extends uvm_sequence #(uvm_sequence_item);
  
 `uvm_object_utils(axi_vbase_seq)

   master_sequencer m_seqrh;
   slave_sequencer s_seqrh;

 axi_virtual_sequencer vsqrh;
/////////////////
master_test_xtns m_xtns;
slave_test_xtns s_xtns;

master_test_aligned_xtns aligned_mxtn;
slave_simple_test_xtns simple_sxtn;

master_test_unaligned_xtns unaligned_mxtn;

master_test_narrow_xtns narrow_mxtn;

///////////////
axi_env_config a_cfg;

extern function new(string name="axi_vbase_seq");
extern task body();
endclass

function axi_vbase_seq::new(string name="axi_vbase_seq");
 super.new(name);
endfunction

task axi_vbase_seq::body();
if(!uvm_config_db #(axi_env_config)::get(null,get_full_name(),"axi_env_config",a_cfg))
		`uvm_fatal("CONFIG","cannot get() axi_env_config.db Have you set() it?")

 assert($cast(vsqrh,m_sequencer)) else begin
  `uvm_error("V_SEQ BASE BODY","Error int $cast of virtual sequencer")
 end
 
 m_seqrh=vsqrh.m_seqrh;
 s_seqrh=vsqrh.s_seqrh; 
endtask

class axi_test_vseq extends axi_vbase_seq;
 `uvm_object_utils(axi_test_vseq)
 
extern function new(string name="axi_test_vseq");
extern task body();
endclass

function axi_test_vseq::new(string name="axi_test_vseq");
 super.new(name);
endfunction

task axi_test_vseq::body();
 super.body();
  m_xtns=master_test_xtns::type_id::create("m_xtns");
  s_xtns=slave_test_xtns::type_id::create("s_xtns");

fork
 begin
 if(a_cfg.has_magent)
	 m_xtns.start(m_seqrh);
 end
 begin 
 if(a_cfg.has_sagent)
   	s_xtns.start(s_seqrh);
  end
join
 
endtask

